<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Litera Bookstore</title>
    
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top border-bottom shadow-sm">
    <div class="container-fluid px-4">
      
      <a class="navbar-brand" href="/">
        <img src="/img/logo.png" alt="logo" width="100">
      </a>
      
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <div class="collapse navbar-collapse" id="navbarNav">
        <form class="d-flex mx-auto w-50" action="#" method="GET">
          <input class="form-control me-2 rounded-pill" type="search" name="query" placeholder="Cari judul, penulis, atau kategori..." aria-label="Search">
          <button class="btn btn-primary rounded-pill" type="submit" aria-label="Cari">
            <i class="bi bi-search"></i>
          </button>
        </form>

        <ul class="navbar-nav ms-auto d-flex flex-row align-items-center">
          <li class="nav-item me-3">
            <a class="nav-link" href="/cart" title="Keranjang">
              <i class="bi bi-cart fs-4"></i>
            </a>
          </li>
          <li class="nav-item me-3">
            <a class="nav-link" href="/profile" title="Profil">
              <i class="bi bi-person-circle fs-4"></i>
            </a>
          </li>
          <li class="nav-item me-3">
            <a class="nav-link" href="/login" title="Login">
              <i class="bi bi-box-arrow-in-right fs-4"></i>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/register" title="Register">
              <i class="bi-pencil-square fs-4"></i>
            </a>
          </li>
        </ul>
      </div>
    </div>
</nav>