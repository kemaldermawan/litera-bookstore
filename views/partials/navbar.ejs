<link class="bootstrap-core-css-anchor" rel="stylesheet" href="/css/bootstrap.min.css">
<link class="platform-custom-css-anchor" rel="stylesheet" href="/css/style.css">
<link class="iconographic-pack-anchor" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm fixed-top" style="height: 64px; padding-top: 0; padding-bottom: 0;">
    <div class="container-fluid px-4 h-100 d-flex align-items-center justify-content-between">
        
        <div class="d-flex align-items-center">
            <a class="navbar-brand fw-bold text-primary text-uppercase letter-spacing-1 m-0" href="/store">Litera</a>
        </div>
        
        <form class="d-flex w-50 justify-content-center align-self-center" action="/search" method=\"GET\" style="padding-top: 10px; margin-bottom: 0;">
            <input class="form-control me-2 rounded-pill px-3 border-secondary" type="search" name="q" placeholder="Search books by title, author, or genre..." aria-label="Search" required>
            <button class="btn btn-primary rounded-pill px-4 d-flex align-items-center" type="submit">
                <i class="bi bi-search me-1"></i>Search
            </button>
        </form>

        <div class="d-flex align-items-center h-100">
            <ul class="navbar-nav d-flex flex-row align-items-center h-100 gap-3 m-0 p-0">
                
                <% if (typeof user !== 'undefined' && user) { %>
                    
                    <% if (user.role === 'user') { %>
                        <li class="nav-item h-100 d-flex align-items-center">
                            <a class="nav-link text-white position-relative px-2" href="/wishlist">
                                <i class="bi bi-heart fs-5"></i>
                            </a>
                        </li>
                        <li class="nav-item h-100 d-flex align-items-center">
                            <a class="nav-link text-white position-relative px-2" href="/cart">
                                <i class="bi bi-basket3 fs-5"></i>
                                <span class="position-absolute top-25 start-75 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
                                    <%= (typeof session !== 'undefined' && session.cart) ? session.cart.reduce((total, item) => total + item.qty, 0) : 0 %>
                                </span>
                            </a>
                        </li>
                    <% } %>

                    <li class="nav-item dropdown h-100 d-flex align-items-center">
                        <a class="nav-link dropdown-toggle d-flex align-items-center text-white h-100 px-3" href="#" id="navbarDropdownProfile" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-2 fs-5 text-primary"></i>
                            <span class="fw-medium"><%= user.username %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3 animate-fade-in" aria-labelledby="navbarDropdownProfile" style="min-width: 200px;">
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-2" href="/auth/profile">
                                    <i class="bi bi-person-bounding-box me-2 text-primary"></i>My Account Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center py-2" href="/auth/profile/edit">
                                    <i class="bi bi-sliders me-2 text-secondary"></i>Profile Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger d-flex align-items-center py-2" href="/auth/logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign Out Securely
                                </a>
                            </li>
                        </ul>
                    </li>

                <% } else { %>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-outline-light px-3 rounded-pill fw-medium" href="/auth/login">Sign In</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-primary px-3 rounded-pill fw-semibold text-white" href="/auth/register">Sign Up</a>
                    </li>
                <% } %>

            </ul>
        </div>

    </div>
</nav>

<div class="navbar-spacing-layer" style="margin-top: 64px;"></div>