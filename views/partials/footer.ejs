    <script>
        function formatRupiah(number) {
            return number.toLocaleString('id-ID');
        }
    
        const qtyInputs = document.querySelectorAll('.cart-qty');
    
        qtyInputs.forEach(input => {
            input.addEventListener('input', function() {
                const parent = this.closest('.cart-item-row');
                const priceElement = parent.querySelector('.total-price');
                const price = parseInt(priceElement.dataset.price);
                const qty = parseInt(this.value) || 0;
    
                // Update total per-item
                priceElement.innerText = "Rp " + formatRupiah(price * qty);
            });
        });

        function updateSummary() {
            let subtotal = 0;
            document.querySelectorAll('.total-price').forEach(item => {
                const number = parseInt(item.innerText.replace(/\D/g, '')) || 0;
                subtotal += number;
            });

            document.getElementById('subtotal').innerText = "Rp " + formatRupiah(subtotal);
            document.getElementById('total').innerText = "Rp " + formatRupiah(subtotal); // free shipping
        }

        qtyInputs.forEach(input => {
            input.addEventListener('input', function() {
                const parent = this.closest('.cart-item-row');
                const priceElement = parent.querySelector('.total-price');
                const price = parseInt(priceElement.dataset.price);
                const qty = parseInt(this.value) || 0;

                priceElement.innerText = "Rp " + formatRupiah(price * qty);

                updateSummary();
            });
        });
    </script>
    
    <script>
        const stars = document.querySelectorAll(".star-icon");
        const ratingInput = document.getElementById("rating-input");
    
        stars.forEach(star => {
            star.addEventListener("click", () => {
                const ratingValue = star.getAttribute("data-value");
    
                // Update input hidden
                ratingInput.value = ratingValue;
    
                // Reset semua bintang
                stars.forEach(s => s.classList.remove("selected"));
    
                // Warnai bintang sesuai rating yang dipilih
                for (let i = 0; i < ratingValue; i++) {
                    stars[i].classList.add("selected");
                }
            });
    
            // Hover effect (optional)
            star.addEventListener("mouseover", () => {
                const ratingValue = star.getAttribute("data-value");
                stars.forEach(s => s.classList.remove("hover"));
                for (let i = 0; i < ratingValue; i++) {
                    stars[i].classList.add("hover");
                }
            });
    
            star.addEventListener("mouseleave", () => {
                stars.forEach(s => s.classList.remove("hover"));
            });
        });
    </script>
    
