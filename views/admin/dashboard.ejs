<%- include('../partials/navbarAdmin') %>
    <div class="container-fluid py-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h2 class="mb-0">Admin Dashboard</h2>
            </div>
            <div class="card-body">
                
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="manajemen-buku-tab" data-bs-toggle="tab" data-bs-target="#manajemen-buku" type="button" role="tab" aria-controls="manajemen-buku" aria-selected="true">Manajemen Buku</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="daftar-transaksi-tab" data-bs-toggle="tab" data-bs-target="#daftar-transaksi" type="button" role="tab" aria-controls="daftar-transaksi" aria-selected="false">Daftar Transaksi</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="daftar-review-tab" data-bs-toggle="tab" data-bs-target="#daftar-review" type="button" role="tab" aria-controls="daftar-review" aria-selected="false">Daftar Review</button>
                    </li>
                </ul>

                <div class="tab-content pt-3" id="myTabContent">
                    
                    <div class="tab-pane fade show active" id="manajemen-buku" role="tabpanel" aria-labelledby="manajemen-buku-tab">
                        
                        <h4 class="mb-3">Tambah Buku Baru</h4>
                        <div class="p-3 mb-4 border rounded">
                            <form action="/admin/books/create" method="POST" enctype="multipart/form-data">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label for="judul" class="form-label">Judul Buku</label>
                                        <input type="text" class="form-control" id="judul" name="judul" required>
                                    </div>
                                    <div class="col-12">
                                        <label for="penulis" class="form-label">Penulis</label>
                                        <input type="text" class="form-control" id="penulis" name="penulis" required>
                                    </div>
                                    <div class="col-12">
                                        <label for="sinopsis" class="form-label">Sinopsis</label>
                                        <textarea class="form-control" id="sinopsis" name="sinopsis" rows="3"></textarea>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="harga" class="form-label">Harga</label>
                                        <input type="text" class="form-control" id="harga" name="harga" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="stok" class="form-label">Stok</label>
                                        <input type="number" class="form-control" id="stok" name="stok" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="kategori" class="form-label">Kategori</label>
                                        <select id="kategori" class="form-select" name="kategori">
                                            <option selected>Fiksi</option>
                                            <option>Non-Fiksi</option>
                                            <option>Edukasi</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="cover" class="form-label">File Cover Buku</label>
                                        <input type="file" class="form-control" id="cover" name="coverImage">
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-success">Tambah Buku</button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <h4 class="mb-3">Daftar Buku</h4>
                        <div class="p-3 border rounded">
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-striped table-hover mb-0">
                                    <thead class="table-light sticky-top" style="z-index: 100; top: -1px;">
                                        <tr>
                                            <th scope="col" style="width: 10%;">Cover</th>
                                            <th scope="col" style="width: 30%;">Judul</th>
                                            <th scope="col" style="width: 25%;">Penulis</th>
                                            <th scope="col" style="width: 10%;">Stok</th>
                                            <th scope="col" style="width: 25%;">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% books.forEach(book => { %>
                                        <tr>
                                            <td>
                                                <img src="<%= book.coverImage %>" 
                                                     class="img-thumbnail" 
                                                     style="width:40px; height:60px; object-fit:cover;">
                                            </td>
                                            <td><strong><%= book.title %></strong></td>
                                            <td><%= book.author %></td>
                                            <td><span class="badge bg-primary"><%= book.stock %></span></td>
                                            <td>
                                                <a href="/admin/books/edit/<%= book._id %>" class="btn btn-sm btn-warning">Edit</a>
                                    
                                                <form action="/admin/books/delete/<%= book._id %>" 
                                                      method="POST" 
                                                      style="display:inline-block;">
                                                    <button class="btn btn-sm btn-danger">Hapus</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                    </tbody>                                    
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="daftar-transaksi" role="tabpanel" aria-labelledby="daftar-transaksi-tab">
                        <h4 class="mb-3">Daftar Transaksi</h4>
                        <div id="transactions-content">
                            <p class="text-center text-muted">Silakan klik tab ini untuk memuat data transaksi.</p>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="daftar-review" role="tabpanel" aria-labelledby="daftar-review-tab">
                        <h4 class="mb-3">Daftar Ulasan Buku</h4>
                        <div id="reviews-content">
                            <p class="text-center text-muted">Silakan klik tab ini untuk memuat data ulasan.</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const tabs = document.querySelectorAll('button[data-bs-toggle="tab"]');
            const loadedTabs = {};

            // Inisiasi event listener untuk tab
            tabs.forEach(tab => {
                // Event ini dipicu setelah tab baru ditampilkan
                tab.addEventListener('shown.bs.tab', function (event) {
                    const targetId = event.target.getAttribute('data-bs-target'); // Contoh: #daftar-transaksi

                    // Cek apakah data untuk tab ini sudah dimuat
                    if (loadedTabs[targetId]) {
                        return; // Jika sudah dimuat, jangan panggil Fetch lagi
                    }

                    let url = '';
                    let contentId = '';

                    if (targetId === '#daftar-transaksi') {
                        // FIX: UBAH URL INI AGAR MATCH DENGAN MOUNTING DI APP.JS + ROUTES
                        url = '/admin/books/data/transactions'; 
                        contentId = 'transactions-content';
                    } else if (targetId === '#daftar-review') {
                        // FIX: UBAH URL INI AGAR MATCH DENGAN MOUNTING DI APP.JS + ROUTES
                        url = '/admin/books/data/reviews';
                        contentId = 'reviews-content';
                    } else {
                        return; // Tab Manajemen Buku (default) tidak perlu AJAX
                    }

                    fetchDataAndRender(url, contentId, targetId);
                });
            });
        });

        async function fetchDataAndRender(url, contentId, targetId) {
            const contentDiv = document.getElementById(contentId);
            
            // Tampilkan loading spinner
            contentDiv.innerHTML = `
                <div class="d-flex justify-content-center align-items-center p-5">
                    <div class="spinner-border text-primary me-2" role="status"></div>
                    <span>Memuat data...</span>
                </div>
            `;

            try {
                const response = await fetch(url);
                
                // Periksa apakah response OK (status 200)
                if (!response.ok) {
                    throw new Error(`Gagal mengambil data: ${response.status} ${response.statusText}`);
                }
                
                const data = await response.json();

                if (data.success) {
                    let html = '';
                    
                    if (targetId === '#daftar-transaksi') {
                        html = generateTransactionsTable(data.transactions);
                    } else if (targetId === '#daftar-review') {
                        html = generateReviewsTable(data.reviews);
                    }

                    contentDiv.innerHTML = html;

                } else {
                    contentDiv.innerHTML = `<p class="alert alert-danger">${data.message || 'Gagal mengambil data.'}</p>`;
                }

            } catch (error) {
                contentDiv.innerHTML = `<p class="alert alert-danger">Error koneksi: ${error.message}</p>`;
            }
        }


        // --- FUNGSI GENERATOR UI ---

        function generateTransactionsTable(transactions) {
            if (transactions.length === 0) {
                return '<p class="alert alert-warning">Belum ada data transaksi.</p>';
            }

            let tableHtml = `
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-striped table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th scope="col">ID Transaksi</th>
                                <th scope="col">Pembeli</th>
                                <th scope="col">Total</th>
                                <th scope="col">Metode</th>
                                <th scope="col">Status</th>
                                <th scope="col">Tanggal</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            transactions.forEach(tx => {
                const status = tx.status || 'Baru'; // Default status jika field kosong
                const statusClass = status === 'Selesai' ? 'bg-success' : status === 'Baru' ? 'bg-primary' : 'bg-warning';
                const formattedDate = new Date(tx.createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });

                tableHtml += `
                    <tr>
                        <td><small class="text-muted">${tx._id}</small></td>
                        <td>${tx.user ? tx.user.username : 'Pengguna Dihapus'}</td>
                        <td><strong>Rp ${tx.totalPrice.toLocaleString('id-ID')}</strong></td>
                        <td>${tx.paymentMethod}</td>
                        <td><span class="badge ${statusClass}">${status}</span></td>
                        <td>${formattedDate}</td>
                    </tr>
                `;
            });

            tableHtml += `</tbody></table></div>`;
            return tableHtml;
        }


        function generateReviewsTable(reviews) {
            if (reviews.length === 0) {
                return '<p class="alert alert-warning">Belum ada data ulasan.</p>';
            }

            let tableHtml = `
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-striped table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th scope="col" style="width: 20%;">Buku</th>
                                <th scope="col" style="width: 15%;">Pengulas</th>
                                <th scope="col" style="width: 15%;">Rating</th>
                                <th scope="col" style="width: 40%;">Ulasan</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            reviews.forEach(review => {
                const ratingStars = '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating);
                const reviewText = review.comment.length > 80 ? review.comment.substring(0, 80) + '...' : review.comment;
                
                tableHtml += `
                    <tr>
                        <td>${review.book ? review.book.title : 'Buku Dihapus'}</td>
                        <td>${review.user ? review.user.username : 'Pengguna Dihapus'}</td>
                        <td><span class="text-warning">${ratingStars}</span></td>
                        <td>${reviewText}</td>
                    </tr>
                `;
            });

            tableHtml += `</tbody></table></div>`;
            return tableHtml;
        }
    </script>
</body>
</html>