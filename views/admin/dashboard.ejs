<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Admin Dashboard - Litera' %></title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">

<%- include('../partials/navbarAdmin') %>

<div class="container-fluid py-4" style="margin-top: 24px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <h2 class="mb-0 fw-bold text-dark"><i class="bi bi-speedometer2 me-2 text-danger"></i>Admin Dashboard Panel</h2>
        </div>
        <div class="card-body p-4">
            
            <ul class="nav nav-tabs" id="adminMasterTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-semibold" id="inventory-management-tab" data-bs-toggle="tab" data-bs-target="#inventory-management" type="button" role="tab" aria-controls="inventory-management" aria-selected="true">
                        <i class="bi bi-book-half me-1"></i>Book Inventory
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold" id="transaction-ledger-tab" data-bs-toggle="tab" data-bs-target="#transaction-ledger" type="button" role="tab" aria-controls="transaction-ledger" aria-selected="false">
                        <i class="bi bi-receipt me-1"></i>Order Management
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold" id="review-logs-tab" data-bs-toggle="tab" data-bs-target="#review-logs" type="button" role="tab" aria-controls="review-logs" aria-selected="false">
                        <i class="bi bi-star-half me-1"></i>Customer Reviews
                    </button>
                </li>
            </ul>

            <div class="tab-content pt-4" id="adminMasterTabContent">
                
                <div class="tab-pane fade show active" id="inventory-management" role="tabpanel" aria-labelledby="inventory-management-tab">
                    <h4 class="fw-bold text-dark mb-3">Add New Book</h4>
                    <div class="p-4 mb-4 border rounded bg-light shadow-sm">
                        <form action="/admin/books/create" method="POST" enctype="multipart/form-data">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="title" class="form-label small fw-bold">Book Title</label>
                                    <input type="text" class="form-control" id="title" name="title" placeholder="Enter book title" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="author" class="form-label small fw-bold">Author</label>
                                    <input type="text" class="form-control" id="author" name="author" placeholder="Author's full name" required>
                                </div>
                                <div class="col-12">
                                    <label for="synopsis" class="form-label small fw-bold">Synopsis</label>
                                    <textarea class="form-control" id="synopsis" name="synopsis" rows="3" placeholder="Provide book synopsis..." required></textarea>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label for="price" class="form-label small fw-bold">Price (IDR)</label>
                                    <input type="number" class="form-control" id="price" name="price" placeholder="e.g., 95000" required>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label for="stock" class="form-label small fw-bold">Stock Quantity</label>
                                    <input type="number" class="form-control" id="stock" name="stock" min="0" placeholder="e.g., 25" required>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label for="category" class="form-label small fw-bold">Genre / Category</label>
                                    <select id="category" class="form-select fw-medium" name="category" required>
                                        <option value="Fiction">Fiction</option>
                                        <option value="Non-Fiction">Non-Fiction</option>
                                        <option value="Technology & Science">Technology & Science</option>
                                        <option value="Comic & Graphic Novel">Comic & Graphic Novel</option>
                                        <option value="Biography & History">Biography & History</option>
                                        <option value="Children & Young Adult">Children & Young Adult</option>
                                        <option value="Textbook & Education">Textbook & Education</option>
                                    </select>
                                </div>
                                <div class="col-md-3 col-6">
                                    <label for="coverImage" class="form-label small fw-bold">Book Cover Image</label>
                                    <input type="file" class="form-control" id="coverImage" name="coverImage" accept="image/*">
                                </div>
                                <div class="col-12 text-end mt-4">
                                    <button type="submit" class="btn btn-success fw-bold px-4 rounded-pill shadow-sm">
                                        <i class="bi bi-plus-circle me-1"></i>Add Book to Catalog
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>

                    <h4 class="fw-bold text-dark mb-3">Current Catalog Listings</h4>
                    <div class="p-3 border rounded bg-white shadow-sm">
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-striped table-hover align-middle mb-0">
                                <thead class="table-dark sticky-top" style="z-index: 10; top: -1px;">
                                    <tr>
                                        <th scope="col" style="width: 10%;">Cover</th>
                                        <th scope="col" style="width: 35%;">Title</th>
                                        <th scope="col" style="width: 25%;">Author</th>
                                        <th scope="col" style="width: 10%;">Stock</th>
                                        <th scope="col" style="width: 20%;" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof books !== 'undefined' && books && books.length > 0) { %>
                                        <% books.forEach(book => { %>
                                            <tr>
                                                <td>
                                                    <img src="<%= book.coverImage %>" alt="<%= book.title %>" class="img-thumbnail shadow-sm" style="width:42px; height:60px; object-fit:cover;">
                                                </td>
                                                <td><strong class="text-dark"><%= book.title %></strong></td>
                                                <td class="text-muted"><%= book.author %></td>
                                                <td>
                                                    <% if (book.stock === 0) { %>
                                                        <span class="badge bg-danger rounded-pill">Out of Stock</span>
                                                    <% } else { %>
                                                        <span class="badge bg-primary rounded-pill px-2.5"><%= book.stock %> units</span>
                                                    <% } %>
                                                </td>
                                                <td class="text-center">
                                                    <div class="d-flex justify-content-center gap-2">
                                                        <a href="/admin/books/edit/<%= book._id %>" class="btn btn-sm btn-warning fw-bold px-3 rounded-pill">
                                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                                        </a>
                                                        <form action="/admin/books/delete/<%= book._id %>" method="POST" onsubmit="return confirm('Are you sure you want to completely remove this book?');">
                                                            <button class="btn btn-sm btn-danger fw-bold px-3 rounded-pill">
                                                                <i class="bi bi-trash3-fill me-1"></i>Delete
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="text-center text-muted py-4">No books registered in the inventory database yet.</td>
                                        </tr>
                                    <% } %>
                                </tbody>                     
                            </table>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="transaction-ledger" role="tabpanel" aria-labelledby="transaction-ledger-tab">
                    <h4 class="fw-bold text-dark mb-3">Order Transactions Management</h4>
                    <div id="transactions-content-container" class="p-3 border rounded bg-white shadow-sm">
                        <p class="text-center text-muted py-4">Loading transaction data streams...</p>
                    </div>
                </div>

                <div class="tab-pane fade" id="review-logs" role="tabpanel" aria-labelledby="review-logs-tab">
                    <h4 class="fw-bold text-dark mb-3">Customer Product Reviews</h4>
                    <div id="reviews-content-container" class="p-3 border rounded bg-white shadow-sm">
                        <p class="text-center text-muted py-4">Loading customer feedback indexes...</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const structuralTabTriggers = document.querySelectorAll('button[data-bs-toggle="tab"]');

        structuralTabTriggers.forEach(tab => {
            tab.addEventListener('shown.bs.tab', function (event) {
                const targetedContainerId = event.target.getAttribute('data-bs-target');
                
                let operationalDataUrl = '';
                let bindingContentId = '';

                if (targetedContainerId === '#transaction-ledger') {
                    operationalDataUrl = '/admin/data/transactions'; 
                    bindingContentId = 'transactions-content-container';
                } else if (targetedContainerId === '#review-logs') {
                    operationalDataUrl = '/admin/data/reviews';
                    bindingContentId = 'reviews-content-container';
                } else {
                    return;
                }

                executeDynamicPipelineFetch(operationalDataUrl, bindingContentId, targetedContainerId);
            });
        });

        async function executeDynamicPipelineFetch(url, contentFieldId, identifierTag) {
            const outputDomContainer = document.getElementById(contentFieldId);
            outputDomContainer.innerHTML = `
                <div class="d-flex justify-content-center align-items-center p-5">
                    <div class="spinner-border text-primary me-3" role="status"></div>
                    <span class="fw-medium text-secondary">Fetching records from server node...</span>
                </div>
            `;
            try {
                const operationalResponse = await fetch(url);
                if (!operationalResponse.ok) throw new Error(`HTTP Error Status: ${operationalResponse.status}`);
                
                const responsePayload = await operationalResponse.json();
                if (responsePayload.success) {
                    let structuredHtmlOutput = '';
                    if (identifierTag === '#transaction-ledger') {
                        structuredHtmlOutput = constructTransactionsTableStructure(responsePayload.transactions);
                    } else if (identifierTag === '#review-logs') {
                        structuredHtmlOutput = constructReviewsTableStructure(responsePayload.reviews);
                    }
                    outputDomContainer.innerHTML = structuredHtmlOutput;
                } else {
                    outputDomContainer.innerHTML = `<div class="alert alert-danger mb-0">${responsePayload.message || 'Data parsing execution failure.'}</div>`;
                }
            } catch (runtimeError) {
                outputDomContainer.innerHTML = `<div class="alert alert-danger mb-0">Connection pipeline failure: ${runtimeError.message}</div>`;
            }
        }

        window.confirmOrderAction = async function(orderId) {
            if (!confirm("Mark this order as Completed? This confirms payment settlement and product hand-over.")) return;
            try {
                const response = await fetch(`/admin/orders/complete/${orderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (response.ok && data.success) {
                    alert("Order status successfully updated to Completed!");
                    executeDynamicPipelineFetch('/admin/data/transactions', 'transactions-content-container', '#transaction-ledger');
                } else {
                    alert(data.message || "Failed to update order status.");
                }
            } catch (err) {
                console.error(err);
                alert("Network communication error.");
            }
        }

        window.deleteReviewAction = async function(reviewId) {
            if (!confirm("Are you sure you want to permanently delete this customer review? This action cannot be undone.")) return;
            try {
                const response = await fetch(`/admin/reviews/delete/${reviewId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (response.ok && data.success) {
                    alert("Customer review successfully deleted!");
                    executeDynamicPipelineFetch('/admin/data/reviews', 'reviews-content-container', '#review-logs');
                } else {
                    alert(data.message || "Failed to delete review.");
                }
            } catch (err) {
                console.error(err);
                alert("Network error processing deletion command.");
            }
        }

        function constructTransactionsTableStructure(transactions) {
            if (!transactions || transactions.length === 0) {
                return '<div class="alert alert-warning mb-0 text-center">No order history records found within the store database.</div>';
            }

            let structuredTable = `
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-striped table-hover align-middle table-sm mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th scope="col">Order ID</th>
                                <th scope="col">Customer</th>
                                <th scope="col">Total Price</th>
                                <th scope="col">Payment Method</th>
                                <th scope="col">Status</th>
                                <th scope="col">Order Date</th>
                                <th scope="col" class="text-center">Control Actions</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            transactions.forEach(tx => {
                const currentStatus = tx.status || 'Pending Pickup';
                let conditionalStatusBadge = 'bg-warning text-dark';
                
                if (currentStatus === 'Completed') conditionalStatusBadge = 'bg-success';
                else if (currentStatus === 'Cancelled' || currentStatus === 'Expired') conditionalStatusBadge = 'bg-danger';

                const localizedDateOutput = new Date(tx.createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' });

                let actionButtonHtml = '';
                if (currentStatus !== 'Completed' && currentStatus !== 'Cancelled') {
                    actionButtonHtml = `
                        <button onclick="confirmOrderAction('${tx._id}')" class="btn btn-xs btn-outline-success fw-bold rounded-pill px-2" style="font-size:0.7rem;">
                            <i class="bi bi-check2-circle me-1"></i>Mark Complete
                        </button>
                    `;
                } else {
                    actionButtonHtml = `<span class="text-muted small fst-italic">No action required</span>`;
                }

                structuredTable += `
                    <tr>
                        <td><small class="text-muted font-monospace">${tx._id}</small></td>
                        <td class="fw-semibold text-dark">${tx.user ? tx.user.username : 'Account Deleted'}</td>
                        <td class="text-danger fw-bold">Rp ${tx.totalPrice.toLocaleString('id-ID')}</td>
                        <td><span class="small font-monospace fw-semibold">${tx.paymentMethod}</span></td>
                        <td><span class="badge ${conditionalStatusBadge} rounded-pill px-2.5">${currentStatus}</span></td>
                        <td class="text-muted small">${localizedDateOutput}</td>
                        <td class="text-center">${actionButtonHtml}</td>
                    </tr>
                `;
            });
            structuredTable += `</tbody></table></div>`;
            return structuredTable;
        }

        function constructReviewsTableStructure(reviews) {
            if (!reviews || reviews.length === 0) {
                return '<div class="alert alert-warning mb-0 text-center">No customer feedback reviews have been logged for any book yet.</div>';
            }

            let structuredTable = `
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-striped table-hover align-middle table-sm mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th scope="col" style="width: 25%;">Target Book</th>
                                <th scope="col" style="width: 20%;">Reviewer Name</th>
                                <th scope="col" style="width: 15%;">Rating Stars</th>
                                <th scope="col" style="width: 30%;">Comment</th>
                                <th scope="col" style="width: 10%;" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
            `;
            reviews.forEach(review => {
                const numericalScore = parseInt(review.rating) || 0;
                const dynamicStarsMatrix = '★'.repeat(numericalScore) + '☆'.repeat(5 - numericalScore);
                const truncatedTextBody = review.comment.length > 80 ? review.comment.substring(0, 80) + '...' : review.comment;
                
                structuredTable += `
                    <tr>
                        <td><strong class="text-dark">${review.book ? review.book.title : 'Book Removed'}</strong></td>
                        <td class="fw-medium text-secondary">${review.user ? review.user.username : 'Anonymous'}</td>
                        <td><span class="text-warning font-monospace">${dynamicStarsMatrix}</span></td>
                        <td class="text-muted fst-italic">"${truncatedTextBody}"</td>
                        <td class="text-center">
                            <button onclick="deleteReviewAction('${review._id}')" class="btn btn-sm btn-outline-danger rounded-pill fw-bold" style="font-size:0.7rem; padding: 2px 10px;">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });
            structuredTable += `</tbody></table></div>`;
            return structuredTable;
        }
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<%- include('../partials/footer') %>
</body>
</html>