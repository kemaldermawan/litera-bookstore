<%- include('../partials/navbarAdmin') %>
    <div class="container-fluid py-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h2 class="mb-0">Admin Dashboard</h2>
            </div>
            <div class="card-body">
                
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="manajemen-buku-tab" data-bs-toggle="tab" data-bs-target="#manajemen-buku" type="button" role="tab" aria-controls="manajemen-buku" aria-selected="true">Manajemen Buku</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="daftar-transaksi-tab" data-bs-toggle="tab" data-bs-target="#daftar-transaksi" type="button" role="tab" aria-controls="daftar-transaksi" aria-selected="false">Daftar Transaksi</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="daftar-review-tab" data-bs-toggle="tab" data-bs-target="#daftar-review" type="button" role="tab" aria-controls="daftar-review" aria-selected="false">Daftar Review</button>
                    </li>
                </ul>

                <div class="tab-content pt-3" id="myTabContent">
                    
                    <div class="tab-pane fade show active" id="manajemen-buku" role="tabpanel" aria-labelledby="manajemen-buku-tab">
                        
                        <h4 class="mb-3">Tambah Buku Baru</h4>
                        <div class="p-3 mb-4 border rounded">
                            <form>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label for="judul" class="form-label">Judul Buku</label>
                                        <input type="text" class="form-control" id="judul" required>
                                    </div>
                                    <div class="col-12">
                                        <label for="penulis" class="form-label">Penulis</label>
                                        <input type="text" class="form-control" id="penulis" required>
                                    </div>
                                    <div class="col-12">
                                        <label for="sinopsis" class="form-label">Sinopsis</label>
                                        <textarea class="form-control" id="sinopsis" rows="3"></textarea>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="harga" class="form-label">Harga</label>
                                        <input type="text" class="form-control" id="harga" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="stok" class="form-label">Stok</label>
                                        <input type="number" class="form-control" id="stok" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="kategori" class="form-label">Kategori</label>
                                        <select id="kategori" class="form-select">
                                            <option selected>Fiksi</option>
                                            <option>Non-Fiksi</option>
                                            <option>Edukasi</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="cover" class="form-label">File Cover Buku</label>
                                        <input type="file" class="form-control" id="cover">
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-success">Tambah Buku</button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <h4 class="mb-3">Daftar Buku</h4>
                        <div class="p-3 border rounded">
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-striped table-hover mb-0">
                                    <thead class="table-light sticky-top" style="z-index: 100; top: -1px;">
                                        <tr>
                                            <th scope="col" style="width: 10%;">Cover</th>
                                            <th scope="col" style="width: 30%;">Judul</th>
                                            <th scope="col" style="width: 25%;">Penulis</th>
                                            <th scope="col" style="width: 10%;">Stok</th>
                                            <th scope="col" style="width: 25%;">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% 
                                        const books = [
                                            { cover: 'placeholder.jpg', title: 'Steve Jobs', author: 'Walter Isaacson', stock: 5 },
                                            { cover: 'placeholder.jpg', title: 'Can\'t Hurt Me', author: 'David Goggins', stock: 10 },
                                            { cover: 'placeholder.jpg', title: 'The Power of Habit', author: 'Charles Duhigg', stock: 12 },
                                            { cover: 'placeholder.jpg', title: 'Sapiens', author: 'Yuval Noah Harari', stock: 8 },
                                            { cover: 'placeholder.jpg', title: 'Atomic Habits', author: 'James Clear', stock: 25 },
                                            { cover: 'placeholder.jpg', title: 'Educated', author: 'Tara Westover', stock: 18 },
                                            { cover: 'placeholder.jpg', title: 'The Hitchhiker\'s Guide to the Galaxy', author: 'Douglas Adams', stock: 3 },
                                            { cover: 'placeholder.jpg', title: 'The Lord of the Rings', author: 'J.R.R. Tolkien', stock: 7 }
                                        ];
                                        books.forEach(book => { 
                                        %>
                                        <tr>
                                            <td><img src="<%= book.cover %>" alt="<%= book.title %> Cover" class="img-thumbnail" style="width: 40px; height: 60px; object-fit: cover;"></td>
                                            <td><strong><%= book.title %></strong></td>
                                            <td><%= book.author %></td>
                                            <td><span class="badge bg-primary"><%= book.stock %></span></td>
                                            <td>
                                                <button class="btn btn-sm btn-warning">Edit</button>
                                                <button class="btn btn-sm btn-danger">Hapus</button>
                                            </td>
                                        </tr>
                                        <% }) %>
                                        </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="daftar-transaksi" role="tabpanel" aria-labelledby="daftar-transaksi-tab">
                        <h4 class="mb-3">Laporan Daftar Transaksi</h4>
                        <p class="alert alert-info">Konten untuk tabel data transaksi akan dimuat di sini.</p>
                    </div>

                    <div class="tab-pane fade" id="daftar-review" role="tabpanel" aria-labelledby="daftar-review-tab">
                        <h4 class="mb-3">Daftar Ulasan Buku</h4>
                        <p class="alert alert-info">Konten untuk moderasi ulasan/review buku akan dimuat di sini.</p>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>