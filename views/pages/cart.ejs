<%- include('../partials/navbar') %>

<link rel="stylesheet" href="/css/#">

<div class="container mt-4 cart-page">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Shopping Cart</h1>
        </div>
    </div>
    
    <div class="row g-5">
        <div class="col-lg-8">
            <div class="cart-box-container p-4">
                <form action="/cart/update" method="POST">
                    <div class="row text-muted small d-none d-md-flex mb-3 border-bottom pb-2">
                        <div class="col-md-6">PRODUK</div>
                        <div class="col-md-3 text-center">KUANTITAS</div>
                        <div class="col-md-3 text-end">TOTAL</div>
                    </div>
                    <div class="row cart-item-row align-items-center py-3">
                        <% if (cart && cart.length > 0) { %>
                            <% cart.forEach(item => { %>
                                <div class="row cart-item-row align-items-center py-3">
                                    <div class="col-md-6 col-8">
                                        <div class="d-flex align-items-center">
                                            <img src="<%= item.coverImage %>" alt="#" class="cart-item-img w-25">
                                            <div class="ms-3">
                                                <h5 class="cart-item-title"><%= item.title %></h5>
                                                <small class="text-muted"><%= item.author %></small>
                                            </div>
                                        </div>
                                    </div>
                        
                                    <div class="col-md-3 col-4 d-flex justify-content-center align-items-center flex-column">
                                        <input 
                                            type="number" 
                                            name="qty[<%= item.bookId %>]"
                                            class="form-control form-control-sm text-center quantity-input" 
                                            min="0" 
                                            value="<%= item.qty %>">
                                        <small class="text-muted d-block d-md-none mt-1">(Set 0 to remove)</small>
                                    </div>
                        
                                    <div class="col-md-3 col-12 text-end mt-2 mt-md-0">
                                        <strong class="fs-5 total-price" data-price="<%= item.price %>">
                                            Rp <%= (item.qty * item.price).toLocaleString('id-ID') %>
                                        </strong>
                                        <form action="/cart/delete/<%= item.bookId %>" method="POST" class="d-inline">
                                            <button class="btn btn-sm btn-danger ms-2">Hapus</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-muted">Keranjang masih kosong.</p>
                        <% } %>                       
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 btn-checkout-now">
                            Update Cart
                        </button>   
                        <a href="/store" class="btn btn-light ms-3 rounded-pill px-4 btn-outline-secondary">Kembali Belanja</a>                     
                    </div>
                </form>
            </div> 
        </div>
        <div class="col-lg-4">
            <div class="cart-box-container p-4">
                <h3 class="mb-4">Ringkasan Pesanan</h3>
                <ul class="list-group list-group-flush summary-list">
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    Subtotal
                    <strong id="subtotal">Rp <%= subtotal.toLocaleString('id-ID') %></strong>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                    Biaya Pengiriman
                    <span class="text-success">Gratis</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0 fs-5 fw-bold border-top pt-3">
                    Total
                    <strong id="total">Rp <%= total.toLocaleString('id-ID') %></strong>
                </li>
                </ul>
                <div class="d-grid mt-4">
                <a href="/checkout" class="btn btn-primary btn-lg btn-checkout-now rounded-pill text-white">
                    Checkout
                </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>