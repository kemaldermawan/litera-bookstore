<%- include('../partials/navbar') %>

<div class="container cart-page-infrastructure mb-5" style="margin-top: 24px;">
    
    <div class="row mb-4 border-bottom pb-2">
        <div class="col-12">
            <h2 class="fw-bold text-dark mb-1">Shopping Cart</h2>
            <p class="text-muted mb-0">Review your selected items and adjust quantities before proceeding to checkout</p>
        </div>
    </div>
    
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show rounded-3 small mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-3 small mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="p-4 bg-white border rounded shadow-sm">
                
                <% if (typeof cart !== 'undefined' && cart && cart.length > 0) { %>
                    <form action="/cart/update" method="POST" id="cartBatchUpdateForm">
                        
                        <div class="row text-muted small fw-bold d-none d-md-flex mb-3 border-bottom pb-2">
                            <div class="col-md-6">BOOK DETAILS</div>
                            <div class="col-md-3 text-center">QUANTITY</div>
                            <div class="col-md-3 text-end">TOTAL PRICE</div>
                        </div>

                        <% cart.forEach((item, index) => { %>
                            <div class="row align-items-center py-3 border-bottom <%= index === cart.length - 1 ? 'border-0 pb-0' : '' %>">
                                
                                <div class="col-md-6 col-12 mb-3 mb-md-0">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= item.coverImage %>" alt="<%= item.title %>" class="rounded border me-3 shadow-sm bg-light" style="width: 70px; height: 95px; object-fit: cover;">
                                        <div class="text-truncate">
                                            <h6 class="fw-bold text-dark text-truncate mb-1" title="<%= item.title %>"><%= item.title %></h6>
                                            <p class="text-danger fw-semibold font-sm mb-2">Rp <%= item.price.toLocaleString('id-ID') %></p>
                                            
                                            <a href="/cart/delete/<%= item.bookId %>" class="text-secondary hover-danger text-decoration-none small font-sm d-inline-flex align-items-center gap-1">
                                                <i class="bi bi-trash3-fill"></i> Remove
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-3 col-6 text-center">
                                    <div class="input-group input-group-sm mx-auto" style="max-width: 110px;">
                                        <input type="number" 
                                            name="qty[<%= item.bookId %>]" 
                                            class="form-control text-center fw-semibold rounded" 
                                            value="<%= item.qty %>" 
                                            min="1" 
                                            required>
                                    </div>
                                </div>
                                
                                <div class="col-md-3 col-6 text-end">
                                    <span class="fw-bold text-dark">
                                        Rp <%= (item.price * item.qty).toLocaleString('id-ID') %>
                                    </span>
                                </div>

                            </div>
                        <% }) %>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a href="/store" class="btn btn-outline-secondary btn-sm fw-semibold rounded-pill px-3">
                                <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                            </a>
                            <button type="submit" class="btn btn-dark btn-sm fw-semibold rounded-pill px-4">
                                <i class="bi bi-arrow-clockwise me-1"></i> Update Cart
                            </button>
                        </div>

                    </form>
                <% } else { %>
                    <div class="text-center py-5">
                        <div class="display-1 text-muted mb-3"><i class="bi bi-cart-x"></i></div>
                        <h4 class="fw-bold text-dark mb-2">Your Cart is Empty</h4>
                        <p class="text-secondary small mb-4">You haven't added any academic books to your cart yet.</p>
                        <a href="/store" class="btn btn-primary fw-semibold rounded-pill text-white px-4 shadow-sm">
                            Browse Store Listings
                        </a>
                    </div>
                <% } %>

            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="p-4 bg-white border rounded shadow-sm sticky-top" style="top: 100px; z-index: 10;">
                <h5 class="fw-bold text-dark mb-3 border-bottom pb-2">Order Summary</h5>
                
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent text-secondary small">
                        Subtotal Items
                        <span class="text-dark fw-semibold">
                            Rp <%= typeof subtotal !== 'undefined' ? subtotal.toLocaleString('id-ID') : '0' %>
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent text-secondary small">
                        Shipping Fee
                        <span class="text-success fw-bold text-uppercase">Free</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent fs-5 fw-bold border-top pt-3">
                        Total Amount
                        <strong class="text-danger" id="ledgerTotalNode">
                            Rp <%= typeof total !== 'undefined' ? total.toLocaleString('id-ID') : '0' %>
                        </strong>
                    </li>
                </ul>

                <% if (typeof cart !== 'undefined' && cart && cart.length > 0) { %>
                    <div class="d-grid">
                        <a href="/checkout" class="btn btn-primary btn-lg fw-bold rounded-pill py-2.5 shadow-sm text-white fs-6">
                            Proceed to Checkout<i class="bi bi-shield-lock-fill ms-2"></i>
                        </a>
                    </div>
                <% } else { %>
                    <div class="d-grid">
                        <button class="btn btn-secondary btn-lg fw-bold rounded-pill py-2.5 shadow-sm fs-6" disabled>
                            Checkout Disabled
                        </button>
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>

<style>
    .font-sm { font-size: 0.75rem; }
    .cart-page-infrastructure { min-height: 75vh; }
    .hover-danger:hover { color: #dc3545 !important; transition: color 0.15s ease-in-out; }
</style>

<%- include('../partials/footer') %>