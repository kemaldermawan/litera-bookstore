<%- include('../partials/navbar') %>

<div class="container my-5">
    <h2 class="mb-4">Hasil Pencarian: "<%= keyword %>"</h2>

    <% if (books.length === 0) { %>
        <p>Tidak ada buku ditemukan.</p>
    <% } else { %>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
            <% books.forEach(book => { %>
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm">
                        <a href="/store/book/<%= book._id %>">
                            <img src="<%= book.coverImage %>" class="card-img-top" style="height: 350px; object-fit: cover;">
                        </a>

                        <div class="card-body">
                            <h6 class="fw-bold text-truncate"><%= book.title %></h6>
                            <p class="text-muted small mb-2"><%= book.author %></p>
                            <p class="fw-bold text-primary">Rp <%= book.price.toLocaleString('id-ID') %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
