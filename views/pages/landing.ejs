<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Litera Bookstore</title>

    <link rel="stylesheet" href="/css/bootstrap.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
         /* Warna biru muda untuk tombol outline */
        .light-blue {
            color: #5bc0de !important;           /* Tulisan biru muda */
            border-color: #5bc0de !important;    /* Garis outline biru muda */
            background-color: #ffffff !important; /* Latar putih */
        }

        /* Efek saat hover (biar ada sedikit interaksi) */
        .light-blue:hover {
            background-color: #5bc0de !important; /* Isi biru muda */
            color: #ffffff !important;            /* Tulisan putih saat hover */
            border-color: #5bc0de !important;
        }
        
        .light-orange {
            color: #f8b26a !important;
            border-color: #f8b26a !important;
            background-color: #ffffff !important;
        }

        .light-orange:hover {
            background-color: #f8b26a !important;
            color: #ffffff !important;
            border-color: #f8b26a !important;
        }

        .gradient-text {
            background: linear-gradient(90deg, #6ecbff, #ffb877);
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-light border-bottom py-3">
      <div class="container">
        <a class="navbar-brand" href="/index">
            <img src="/img/logo.png" alt="logo" width="100">
        </a>

        <div class="d-flex align-items-center ms-auto">
          <ul class="list-unstyled d-flex mb-0 me-4">
            <li class="ms-3">
              <a href="#"><i class="bi bi-facebook text-dark fs-4"></i></a>
            </li>
            <li class="ms-3">
              <a href="#"><i class="bi bi-instagram text-dark fs-4"></i></a>
            </li>
            <li class="ms-3">
              <a href="#"><i class="bi bi-tiktok text-dark fs-4"></i></a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <header class="container py-5">
      <div class="row align-items-center">
        <div class="col-md-6 text-center text-md-start">
          <h1 class="fw-bold display-5 mb-3">
            Temukan Dunia Pengetahuan di
            <span class="gradient-text">Litera</span>
          </h1>
          <p class="text-secondary mb-4">
            Nikmati pengalaman membaca dan belajar yang lebih baik dengan akses
            ribuan buku digital, artikel, dan sumber pengetahuan dalam satu
            platform.
          </p>

          <form class="bg-white rounded p-2">
            <div class="row g-2">
              <div class="col-md-5">
                <a class="btn btn-outline-primary light-blue me-2" href="/login" title="login">Login</a>
                <a class="btn btn-primary light-orange" href="/register" title="register">Register</a>
              </div>
            </div>
          </form>
        </div>

        <div class="col-md-6 mt-4 mt-md-0 text-center">
          <img
            src="/img/landing.jpg"
            alt="Litera Books"
            class="img-fluid rounded"
          />
        </div>
      </div>
    </header>

    <!-- Footer -->
    <footer class="bg-light py-3 mt-5 border-top">
      <div class="container text-center text-secondary small">
        &copy; 2025 Litera. All Rights Reserved.
      </div>
    </footer>

    <!-- Bootstrap JS -->
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>
