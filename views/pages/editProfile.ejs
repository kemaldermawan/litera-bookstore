<%- include('../partials/navbar') %>

<div class="container-fluid p-0 pb-5 edit-profile-infrastructure" style="margin-top: -32px;">
    <div class="row m-0 w-100">
        <div class="col-12 p-0">
            
            <div class="card border-0 rounded-0 overflow-hidden bg-white">
                <div class="row g-0">
                    
                    <div class="col-md-4 col-lg-3 bg-light d-flex flex-column align-items-center p-4 p-lg-5 border-end border-secondary border-opacity-10" style="justify-content: flex-start !important; padding-top: 60px !important;">
                        <div class="mb-4 position-relative d-inline-block mx-auto">
                            <img src="<%= user.profilePicture || '/img/default-avatar.png' %>" alt="Avatar preview" id="previewImage" class="rounded-circle img-thumbnail shadow-sm border-2 border-primary bg-white p-1" style="width: 160px; height: 160px; object-fit: cover;">
                        </div>
                        <div class="text-center w-100 px-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1.5 small fw-bold text-uppercase mb-2 d-inline-block">Account Identity</span>
                            <h5 class="fw-bold text-dark mb-1"><%= user.username || 'System User' %></h5>
                            <p class="text-muted small mb-0 text-truncate"><%= user.email || 'Update your details below' %></p>
                        </div>
                    </div>

                    <div class="col-md-8 col-lg-9 p-4 p-lg-5 d-flex flex-column justify-content-center">
                        
                        <div class="mb-4 border-bottom pb-3">
                            <h3 class="fw-bold text-dark mb-1">Edit Profile Settings</h3>
                            <p class="text-muted small mb-0">Update your account information, personal bio, and delivery address coordinates.</p>
                        </div>

                        <form action="/auth/profile/edit" method="POST" enctype="multipart/form-data" id="editProfileForm">
      
                            <div class="mb-4 bg-light p-4 rounded-3 border">
                                <label class="form-label fw-bold text-dark small mb-2"><i class="bi bi-camera text-primary me-1"></i> Update Profile Picture</label>
                                <div class="mx-auto" style="max-width: 400px; margin-left: 0 !important;">
                                    <input type="file" class="form-control form-control-sm rounded-pill border-secondary border-opacity-25" id="profilePicture" name="profilePicture" accept="image/*">
                                    <small class="text-muted d-block mt-2 font-sm"><i class="bi bi-info-circle me-1"></i>Accepted formats: JPG, JPEG, or PNG (Max size: 2MB)</small>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="bio" class="form-label fw-bold text-dark small"><i class="bi bi-person-lines-fill text-secondary me-1"></i> Biography</label>
                                <textarea class="form-control bg-light border-secondary border-opacity-25 small-placeholder px-3 py-3 rounded-3" id="bio" name="bio" rows="4" maxlength="200" placeholder="Tell us a little bit about yourself, your favorite genres, or reading preferences..." style="resize: none;"><%= user.bio || '' %></textarea>
                                <div class="text-end text-muted font-sm mt-1">
                                    <span id="charCount">0</span> / 200 characters
                                </div>
                            </div>

                            <h5 class="fw-bold text-dark mb-3 pt-3 border-bottom pb-2">
                                <i class="bi bi-truck text-primary me-2"></i> Shipping & Contact Details
                            </h5>

                            <div class="mb-3">
                                <label for="phone" class="form-label fw-bold text-secondary small">Phone Number</label>
                                <input type="tel" class="form-control bg-light border-secondary border-opacity-25 rounded-3 px-3 py-2" id="phone" name="phone" value="<%= user.phone || '' %>" required placeholder="e.g., 081234567890">
                            </div>

                            <div class="mb-3">
                                <label for="street" class="form-label fw-bold text-secondary small">Street Address</label>
                                <input type="text" class="form-control bg-light border-secondary border-opacity-25 rounded-3 px-3 py-2" id="street" name="address[street]" value="<%= (user.address && user.address.street) ? user.address.street : '' %>" required placeholder="e.g., Jl. Rawamangun Muka No. 1">
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                   <label for="city" class="form-label fw-bold text-secondary small">City</label>
                                    <input type="text" class="form-control bg-light border-secondary border-opacity-25 rounded-3 px-3 py-2" id="city" name="address[city]" value="<%= (user.address && user.address.city) ? user.address.city : '' %>" required placeholder="e.g., Jakarta Timur">
                                </div>
                                <div class="col-md-6">
                                    <label for="postalCode" class="form-label fw-bold text-secondary small">Postal Code</label>
                                    <input type="text" class="form-control bg-light border-secondary border-opacity-25 rounded-3 px-3 py-2" id="postalCode" name="address[postalCode]" value="<%= (user.address && user.address.postalCode) ? user.address.postalCode : '' %>" required placeholder="e.g., 13220">
                                </div>
                            </div>

                            <div class="row g-3 border-top pt-4 mt-2">
                                <div class="col-sm-6">
                                    <a href="/auth/profile" class="btn btn-outline-secondary btn-md fw-semibold rounded-pill w-100 py-2.5 transition-all">
                                        <i class="bi bi-x-circle me-1"></i> Cancel Changes
                                    </a>
                                </div>
                                <div class="col-sm-6">
                                   <button type="submit" class="btn btn-primary btn-md fw-bold rounded-pill w-100 py-2.5 text-white shadow-sm transition-all">
                                        Save Profile Settings <i class="bi bi-check2-circle ms-1"></i>
                                    </button>
                                </div>
                            </div>

                        </form>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const fileInputNode = document.getElementById('profilePicture');
        const previewImageNode = document.getElementById('previewImage');
        const bioTextareaNode = document.getElementById('bio');
        const charCountDisplay = document.getElementById('charCount');

        if (fileInputNode && previewImageNode) {
            fileInputNode.addEventListener('change', function(e) {
                const targetedFile = e.target.files[0];
                if (targetedFile) {
                    const localReaderNode = new FileReader();
                    localReaderNode.onload = function(event) {
                        previewImageNode.src = event.target.result;
                    };
                    localReaderNode.readAsDataURL(targetedFile);
                }
            });
        }

        if (bioTextareaNode && charCountDisplay) {
            charCountDisplay.textContent = bioTextareaNode.value.length;
            bioTextareaNode.addEventListener('input', function() {
                charCountDisplay.textContent = this.value.length;
            });
        }
    });
</script>

<style>
    .font-sm { font-size: 0.75rem; }
    .small-placeholder::placeholder { font-size: 0.85rem; color: #adb5bd; }
    .edit-profile-infrastructure { min-height: calc(100vh - 72px); }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .transition-all:hover {
        transform: translateY(-2px);
    }
</style>

<%- include('../partials/footer') %>