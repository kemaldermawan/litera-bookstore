<%- include('../partials/navbar') %>

<%
  const banners = [
    { image: "/img/carousel-1.png", alt: "Promo 1" },
    { image: "/img/carousel-2.png", alt: "Promo 2" }
  ];
%>
<div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <% banners.forEach((_, index) => { %>
      <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= index %>" class="<%= index === 0 ? 'active' : '' %>"></button>
    <% }); %>
  </div>
  <div class="carousel-inner">
    <% banners.forEach((banner, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
        <img src="<%= banner.image %>" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="<%= banner.alt %>">
      </div>
    <% }); %>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
  </button>
</div>

<div class="container">

    <% function renderBookSection(title, books) { %>
        <% if (books && books.length > 0) { %>
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="fw-bold border-start border-4 border-primary ps-3"><%= title %></h3>
                    <a href="#" class="text-decoration-none">Lihat Semua &rarr;</a>
                </div>
                
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
                    <% books.forEach(book => { %>
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm book-card">
                                <a href="/store/book/<%= book._id %>">
                                    <img src="<%= book.coverImage %>" class="card-img-top" alt="<%= book.title %>" style="height: 350px; object-fit: cover;">
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold text-truncate" title="<%= book.title %>">
                                        <a href="/store/book/<%= book._id %>" class="text-decoration-none text-dark">
                                            <%= book.title %>
                                        </a>
                                    </h6>
                                    <p class="text-muted small mb-2"><%= book.author %></p>
                                    <div class="mt-auto">
                                        <p class="fw-bold text-primary mb-2">Rp <%= book.price.toLocaleString('id-ID') %></p>
                                        <form action="/cart/add/<%= book._id %>" method="POST">
                                            <button class="btn btn-primary btn-sm w-100 rounded-pill" type="submit">
                                                Tambah Keranjang
                                            </button>
                                        </form>                                        
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </section>
        <% } %>
    <% } %>

    <% renderBookSection('New Arrivals', newArrivals) %>

    <% renderBookSection('Best Seller', bestsellers) %>

    <div class="my-5">
        <img src="/img/carousel-2.png" class="img-fluid w-100 rounded shadow-sm" alt="Promo Spesial" style="height: 200px; object-fit: cover;">
    </div>

    <% if (fiction && fiction.length > 0) { %>
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold border-start border-4 border-primary ps-3">Literary & General Fiction</h3>
            <a href="#" class="text-decoration-none">Lihat Semua &rarr;</a>
        </div>
        
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
            <% fiction.forEach(book => { %>
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm book-card">
                        <a href="/store/book/<%= book._id %>">
                            <img src="<%= book.coverImage %>" class="card-img-top" alt="<%= book.title %>" style="height: 350px; object-fit: cover;">
                        </a>
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold text-truncate" title="<%= book.title %>">
                                <a href="/store/book/<%= book._id %>" class="text-decoration-none text-dark">
                                    <%= book.title %>
                                </a>
                            </h6>
                            <p class="text-muted small mb-2"><%= book.author %></p>
                            <div class="mt-auto">
                                <p class="fw-bold text-primary mb-2">Rp <%= book.price.toLocaleString('id-ID') %></p>
                                <form action="/cart/add/<%= book._id %>" method="POST">
                                    <button class="btn btn-primary btn-sm w-100 rounded-pill" type="submit">
                                        Tambah Keranjang
                                    </button>
                                </form>                                
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
    <% } %>

    <% if (nonFiction && nonFiction.length > 0) { %>
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold border-start border-4 border-primary ps-3">Non-Fiction</h3>
            <a href="#" class="text-decoration-none">Lihat Semua &rarr;</a>
        </div>
        
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4">
            <% nonFiction.forEach(book => { %>
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm book-card">
                        <a href="/store/book/<%= book._id %>">
                            <img src="<%= book.coverImage %>" class="card-img-top" alt="<%= book.title %>" style="height: 350px; object-fit: cover;">
                        </a>
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold text-truncate" title="<%= book.title %>">
                                <a href="/store/book/<%= book._id %>" class="text-decoration-none text-dark">
                                    <%= book.title %>
                                </a>
                            </h6>
                            <p class="text-muted small mb-2"><%= book.author %></p>
                            <div class="mt-auto">
                                <p class="fw-bold text-primary mb-2">Rp <%= book.price.toLocaleString('id-ID') %></p>
                                <form action="/cart/add/<%= book._id %>" method="POST">
                                    <button class="btn btn-primary btn-sm w-100 rounded-pill" type="submit">
                                        Tambah Keranjang
                                    </button>
                                </form>                                
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
    <% } %>

    <% renderBookSection('Sci-Fi & Fantasy', scifi) %>
    <% renderBookSection('Mystery & Thriller', mystery) %>
    <% renderBookSection('Biography', biography) %>

</div>

<%- include('../partials/footer') %>