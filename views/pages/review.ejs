<%- include('../partials/navbar') %>

<div class="container-fluid p-0 pb-5 review-generation-infrastructure" style="margin-top: -32px;">
    <div class="row m-0 w-100">
        <div class="col-12 p-0">
            <div class="card border-0 rounded-0 overflow-hidden bg-white">
                <div class="row g-0">
                    
                    <div class="col-md-5 bg-light d-flex flex-column align-items-center justify-content-center p-4 p-lg-5 border-end border-secondary border-opacity-10">
                        <div class="position-relative text-center mb-4 shadow rounded-3 overflow-hidden bg-white p-3" style="max-width: 220px; aspect-ratio: 2/3;">
                            <img src="<%= book.coverImage %>" alt="<%= book.title %>" class="img-fluid rounded-2" style="max-height: 280px; object-fit: contain;">
                        </div>
                        <div class="text-center w-100 px-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1.5 small fw-bold text-uppercase mb-2 d-inline-block">Product Asset</span>
                            <h4 class="fw-bold text-dark mb-2 text-truncate-2" title="<%= book.title %>"><%= book.title %></h4>
                            <p class="text-muted small mb-0">Written by <span class="fw-semibold text-secondary"><%= book.author %></span></p>
                        </div>
                    </div>

                    <div class="col-md-7 p-4 p-lg-5 d-flex flex-column justify-content-center">
                        <div class="mb-4 border-bottom pb-3">
                            <h3 class="fw-bold text-dark mb-1">Submit Evaluation</h3>
                            <p class="text-muted small mb-0">Your factual feedback helps other researchers and readers make informed purchasing decisions.</p>
                        </div>

                        <form action="/review/<%= book._id %>" method="POST" id="publicAssetReviewForm">
                            
                            <div class="mb-4 text-center bg-light p-4 rounded-3 border">
                                <label class="form-label d-block fw-bold text-dark small text-uppercase mb-3">
                                    <i class="bi bi-star-half text-warning me-1"></i> Quality Score Metrics
                                </label>
                                
                                <div id="star-rating" class="d-flex justify-content-center gap-3 mb-2">
                                    <i class="bi bi-star-fill star-icon text-muted fs-2 cursor-pointer" data-value="1"></i>
                                    <i class="bi bi-star-fill star-icon text-muted fs-2 cursor-pointer" data-value="2"></i>
                                    <i class="bi bi-star-fill star-icon text-muted fs-2 cursor-pointer" data-value="3"></i>
                                    <i class="bi bi-star-fill star-icon text-muted fs-2 cursor-pointer" data-value="4"></i>
                                    <i class="bi bi-star-fill star-icon text-muted fs-2 cursor-pointer" data-value="5"></i>
                                </div>
                                
                                <input type="hidden" name="rating" id="rating-input" value="0" required>
                                <div id="ratingValidationFeedback" class="text-danger font-sm d-none mt-3 fw-medium">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Please select a valid rating score before submitting.
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="comment" class="form-label fw-bold text-dark small">
                                    <i class="bi bi-pencil-square text-secondary me-1"></i> Written Review Comment
                                </label>
                                <textarea class="form-control bg-light border-secondary border-opacity-25 small-placeholder px-3 py-3 rounded-3" id="comment" name="comment" rows="5" placeholder="Provide factual details regarding content accuracy, compilation quality, or print durability..." required style="resize: none;"></textarea>
                            </div>
     
                            <div class="row g-3 border-top pt-4 mt-2">
                                <div class="col-sm-6">
                                    <a href="/auth/profile" class="btn btn-outline-secondary btn-md fw-semibold rounded-pill w-100 py-2.5 transition-all">
                                        <i class="bi bi-arrow-left-circle me-1"></i> Abort Review
                                    </a>
                                </div>
                                <div class="col-sm-6">
                                    <button type="submit" id="submitReviewBtn" class="btn btn-primary btn-md fw-bold rounded-pill w-100 py-2.5 text-white shadow-sm transition-all">
                                        Dispatch Review <i class="bi bi-send-fill ms-1"></i>
                                    </button>
                                </div>
                            </div>

                        </form>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .font-sm { font-size: 0.75rem; }
    .small-placeholder::placeholder { font-size: 0.85rem; color: #adb5bd; }
    .review-generation-infrastructure { min-height: calc(100vh - 96px); }
    .cursor-pointer { cursor: pointer; }
    
    #star-rating .star-icon {
        transition: color 0.15s ease-in-out, transform 0.15s ease-in-out;
    }
    #star-rating .star-icon:hover {
        transform: scale(1.15);
    }
    #star-rating .star-icon.hover {
        color: #ffd76d !important;
    }
    #star-rating .star-icon.selected {
        color: #ffc107 !important;
    }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .transition-all:hover {
        transform: translateY(-2px);
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const starElements = document.querySelectorAll('#star-rating .star-icon');
        const ratingInputNode = document.getElementById('rating-input');
        const validationFeedbackNode = document.getElementById('ratingValidationFeedback');
        const formEngine = document.getElementById('publicAssetReviewForm');

        starElements.forEach(star => {
            star.addEventListener('mouseover', function() {
                const currentHoverValue = parseInt(this.getAttribute('data-value'));
                highlightStarsMatrix(currentHoverValue, 'hover');
            });

            star.addEventListener('mouseout', function() {
                removeStarsStyleClass('hover');
            });

            star.addEventListener('click', function() {
                const selectedRatingValue = parseInt(this.getAttribute('data-value'));
                ratingInputNode.value = selectedRatingValue;
                
                removeStarsStyleClass('selected');
                highlightStarsMatrix(selectedRatingValue, 'selected');
                
                if (selectedRatingValue > 0 && validationFeedbackNode) {
                    validationFeedbackNode.classList.add('d-none');
                }
            });
        });

        function highlightStarsMatrix(limitValue, className) {
            starElements.forEach(star => {
                const starValue = parseInt(star.getAttribute('data-value'));
                if (starValue <= limitValue) {
                    star.classList.add(className);
                    if (className === 'selected') {
                        star.classList.remove('text-muted');
                    }
                }
            });
        }

        function removeStarsStyleClass(className) {
            starElements.forEach(star => {
                star.classList.remove(className);
                if (className === 'selected') {
                    star.classList.add('text-muted');
                }
            });
        }

        formEngine.addEventListener('submit', function(event) {
            const finalRatingScore = parseInt(ratingInputNode.value);
            
            if (finalRatingScore === 0 || isNaN(finalRatingScore)) {
                event.preventDefault(); 
                if (validationFeedbackNode) {
                    validationFeedbackNode.classList.remove('d-none');
                }
            }
        });
    });
</script>

<%- include('../partials/footer') %>