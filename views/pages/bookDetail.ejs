<%- include('../partials/navbar') %>

<div class="book-detail-hero bg-light py-4" style="margin-top: 24px;">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-md-4 text-center">
                <div class="p-3 bg-white rounded shadow-sm d-inline-block">
                    <img src="<%= book.coverImage %>" alt="<%= book.title %>" class="img-fluid rounded" style="max-height: 340px; object-fit: contain;">
                </div>
            </div>

            <div class="col-md-8 mt-4 mt-md-0">
                <span class="badge bg-primary mb-2 rounded-pill px-3 py-2"><%= book.category %></span>
                <h1 class="display-5 fw-bold text-dark mb-1"><%= book.title %></h1>
                <p class="fs-5 text-secondary mb-3">By <span class="text-dark fw-semibold"><%= book.author %></span></p>

                <div class="d-flex align-items-center mb-4 text-muted small">
                    <div class="d-flex align-items-center me-3">
                        <span class="text-warning fs-5 me-1">
                            <% const currentRating = typeof book.averageRating !== 'undefined' ? book.averageRating : 0; %>
                            <%= '★'.repeat(Math.round(currentRating)) %><%= '☆'.repeat(5 - Math.round(currentRating)) %>
                        </span>
                        <span class="fw-bold text-dark">(<%= reviews.length %> Reviews)</span>
                    </div>
                    <span class="me-3">|</span>
                    <span class="me-3"><i class="bi bi-cart-check me-1"></i>Total Sold: <strong class="text-dark"><%= book.salesCount || 0 %> items</strong></span>
                </div>

                <h2 class="text-danger fw-extrabold mb-4">Rp <%= book.price.toLocaleString('id-ID') %></h2>

                <div class="mb-4">
                    <% if (book.stock > 10) { %>
                        <span class="badge bg-success font-sm px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>In Stock: <%= book.stock %> units available</span>
                    <% } else if (book.stock > 0) { %>
                        <span class="badge bg-warning text-dark font-sm px-3 py-2 rounded-pill"><i class="bi bi-exclamation-triangle-fill me-1"></i>Limited Stock: Only <%= book.stock %> units left</span>
                    <% } else { %>
                        <span class="badge bg-danger font-sm px-3 py-2 rounded-pill"><i class="bi bi-x-circle-fill me-1"></i>Out of Stock</span>
                    <% } %>
                </div>

                <% if (typeof user === 'undefined' || !user || user.role === 'user') { %>
                    <% if (book.stock > 0) { %>
                        <div class="d-flex flex-wrap align-items-center gap-3">
                            
                            <% if (typeof user === 'undefined' || !user) { %>
                                <a href="/auth/login?error=Please log in to add items to your cart." class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                                    <i class="bi bi-cart-plus me-1"></i>Add To Cart
                                </a>
                            <% } else { %>
                                <form action="/cart/add/<%= book._id %>" method="POST" class="m-0 p-0 ajax-cart-form">
                                    <button type="submit" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                                        <i class="bi bi-cart-plus me-1"></i>Add To Cart
                                    </button>
                                </form>
                            <% } %>
                            
                            <% if (typeof user === 'undefined' || !user) { %>
                                <a href="/auth/login?error=Please log in to add items to your wishlist." class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-pill shadow-sm">
                                    <i class="bi bi-heart me-1"></i>Add To Wishlist
                                </a>
                            <% } else { %>
                                <form action="/wishlist/add/<%= book._id %>" method="POST" class="m-0 p-0 ajax-wishlist-form">
                                    <button type="submit" class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-pill shadow-sm">
                                        <i class="bi bi-heart me-1"></i>Add To Wishlist
                                    </button>
                                </form>
                            <% } %>

                            <% if (typeof user === 'undefined' || !user) { %>
                                <a href="/auth/login?error=Please log in to buy items." class="btn btn-primary fw-bold px-5 py-2 rounded-pill shadow-sm text-white">
                                    Buy Now
                                </a>
                            <% } else { %>
                                <a href="/checkout?isBuyNow=true&bookId=<%= book._id %>" class="btn btn-primary fw-bold px-5 py-2 rounded-pill shadow-sm text-white">
                                    Buy Now
                                </a>
                            <% } %>

                        </div>
                    <% } else { %>
                        <button class="btn btn-secondary fw-bold px-4 py-2.5 rounded-pill shadow-sm" disabled>
                            <i class="bi bi-bell-slash me-1"></i>Unavailable
                        </button>
                    <% } %>
                <% } %>

                <% if(hasPurchased){ %>
                    <div class="d-flex">
                        <button class="btn btn-success fw-bold py-2 rounded-pill shadow-sm w-100" 
                            id="purchased-btn" disabled style="max-width: 360px;">
                            <i class="bi bi-check-circle-fill me-1"></i>Purchased
                        </button>
                    </div>
                <% } %>

            </div>

        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <article class="p-4 p-md-5 bg-white border rounded shadow-sm mb-5">
                <h4 class="fw-bold text-dark mb-3 border-bottom pb-2">Synopsis</h4>
                <p class="text-secondary lh-lg mb-0" style="text-align: justify;"><%= book.synopsis %></p>
            </article>

            <section class="p-4 p-md-5 bg-white border rounded shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                    <h4 class="fw-bold text-dark mb-0">Customer Reviews</h4>
                    
                    <% if (typeof user !== 'undefined' && user && user.role === 'user' && typeof hasPurchased !== 'undefined' && hasPurchased) { %>
                        <% if (typeof hasReviewed !== 'undefined' && hasReviewed) { %>
                            <span class="badge bg-secondary font-sm rounded-pill px-3 py-2">
                                <i class="bi bi-check-circle-fill me-1"></i>You have reviewed this book
                            </span>
                        <% } else { %>
                            <a href="/review/<%= book._id %>" class="btn btn-sm btn-dark fw-semibold rounded-pill px-3">
                                <i class="bi bi-pencil-square me-1"></i>Write a Review
                            </a>
                        <% } %>
                    <% } %>
                </div>

                <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
                    <div class="vstack gap-4">
                        <% reviews.forEach(review => { %>
                            <div class="p-3 bg-light rounded border-start border-primary border-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 text-dark"><%= review.user ? review.user.username : 'Anonymous' %></h6>
                                    <span class="text-warning small">
                                        <%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %>
                                    </span>
                                </div>
                                <p class="text-muted small mb-1">Reviewed on: <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                                <p class="text-secondary mb-0 small"><%= review.comment %></p>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-4 bg-light rounded border border-dashed">
                        <p class="text-muted mb-0 fst-italic small">No reviews available for this book yet.</p>
                    </div>
                <% } %>
            </section>
        </div>

        <div class="col-lg-4 mt-5 mt-lg-0">
            <div class="p-4 bg-white border rounded shadow-sm sticky-top" style="top: 100px; z-index: 1000;">
                <h5 class="fw-bold text-dark mb-3 border-bottom pb-2">Related Books</h5>
                
                <% if (typeof relatedBooks !== 'undefined' && relatedBooks && relatedBooks.length > 0) { %>
                    <div class="vstack gap-3">
                        <% relatedBooks.slice(0, 3).forEach(rb => { %>
                            <a href="/store/book/<%= rb._id %>" class="text-decoration-none d-flex align-items-center p-2 rounded hover-bg-light transition-all">
                                <img src="<%= rb.coverImage %>" alt="<%= rb.title %>" class="rounded border me-3" style="width: 60px; height: 80px; object-fit: cover;">
                                <div class="text-truncate">
                                    <h6 class="fw-bold text-dark text-truncate mb-1 small" title="<%= rb.title %>"><%= rb.title %></h6>
                                    <p class="text-muted font-sm mb-1 text-truncate">By <%= rb.author %></p>
                                    <span class="text-danger fw-bold font-sm">Rp <%= rb.price.toLocaleString('id-ID') %></span>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="text-muted font-sm fst-italic mb-0">No related books found.</p>
                <% } %>
                
                <div class="d-grid mt-4 pt-2 border-top">
                    <a href="/store" class="btn btn-outline-secondary btn-sm fw-semibold rounded-pill"><i class="bi bi-arrow-left me-1"></i>Back to Store</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="runtime-popup-alert" class="popup-alert-node" style="display: none;"></div>

<script>
    function showToastAlert(textMessage) {
        const toastNode = document.getElementById('runtime-popup-alert');
        if (toastNode) {
            toastNode.innerHTML = `<i class="bi bi-check-circle-fill me-2"></i>${textMessage}`;
            toastNode.style.display = 'block';
            setTimeout(() => { toastNode.style.display = 'none'; }, 3500);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const cartForms = document.querySelectorAll('.ajax-cart-form');
        cartForms.forEach(form => {
            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                const targetUrl = form.getAttribute('action');
                const submitButton = form.querySelector('button[type="submit"]');
                const originalButtonHtml = submitButton.innerHTML;
                
                submitButton.disabled = true;
                submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Adding...';
                
                try {
                    const response = await fetch(targetUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const result = await response.json();
                    if (response.ok && result.success) {
                        const cartBadge = document.querySelector('.navbar .badge');
                        if (cartBadge) { cartBadge.textContent = Math.max(1, result.cartCount); }
                        showToastAlert(result.message);
                    } else {
                        alert(result.error || 'Failed to add item to cart.');
                    }
                } catch (error) {
                    console.error('AJAX Detail-Cart operational failure:', error);
                } finally {
                    submitButton.disabled = false;
                    submitButton.innerHTML = originalButtonHtml;
                }
            });
        });
    });
</script>

<style>
    .font-sm { font-size: 0.75rem; }
    .hover-bg-light:hover { background-color: #f8f9fa; }
    .transition-all { transition: all 0.2s ease-in-out; }
    .fw-extrabold { font-weight: 800; }
    .popup-alert-node {
        position: fixed;
        top: 90px;
        left: 50%;
        transform: translateX(-50%);
        background: #27ae60;
        color: white;
        padding: 12px 24px;
        border-radius: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        font-weight: 600;
        z-index: 1050;
    }
</style>

<%- include('../partials/footer') %>