<%- include('../partials/navbar') %>

<div class="book-detail-hero">
    <div class="container">
        <div class="row align-items-center g-5">

            <!-- COVER -->
            <div class="col-md-4 text-center">
                <img src="<%= book.coverImage %>"
                     alt="<%= book.title %>"
                     class="img-fluid book-cover-large mt-5"
                     style="max-width: 220px; border-radius: 8px; ">
            </div>

            <!-- DETAIL BUKU -->
            <div class="col-md-8 mt-4 mt-md-0 align-title">
                <h1 class="detail-title"><%= book.title %></h1>
                <p class="detail-author">Oleh <%= book.author %></p>

                <div class="d-flex align-items-center mb-3">
                    <span class="fs-6 text-muted">( <%= book.numReviews %> Ulasan )</span>
                    <span class="fs-6 text-muted ms-3">|</span>
                    <span class="fs-6 text-muted ms-3">Terjual <%= book.salesCount %></span>
                </div>

                <h2 class="detail-price">Rp <%= book.price.toLocaleString() %></h2>

                <!-- STATUS STOK -->
                <div class="d-flex gap-3 mb-4">
                    <% if (book.stock > 10) { %>
                        <span class="badge bg-success fs-6">Stok tersedia</span>
                    <% } else if (book.stock > 0) { %>
                        <span class="badge bg-warning text-dark fs-6">Sisa <%= book.stock %></span>
                    <% } else { %>
                        <span class="badge bg-danger fs-6">Stok Habis</span>
                    <% } %>
                </div>

                <!-- BUTTONS -->
                <div class="action-buttons-container mb-3">

                    <!-- EDIT -->
                    <% if (user && user.role === 'admin') { %>
                        <a href="/admin/books/edit/<%= book._id %>"
                           class="btn btn-outline-primary rounded-pill mb-2 me-4">
                            Edit Buku
                        </a>
                    <% } %>

                    <% if (book.stock <= 0) { %>
                        <button class="btn btn-secondary rounded-pill mb-2" disabled>
                            Stok Habis
                        </button>
                    <% } else { %>
                        <div class="d-flex align-items-center gap-3">
                            <form action="/cart/add/<%= book._id %>" method="POST">
                                <button class="btn btn-outline-primary rounded-pill">
                                    Add to Cart
                                </button>
                            </form>

                            <form action="/checkout" method="GET" class="d-inline">
                                <button type="submit" class="btn btn-primary rounded-pill">
                                    Buy Now
                                </button>
                            </form>
                        </div>
                    <% } %>

                </div>

            </div>
        </div>
    </div>
</div>

<!-- SINOPSIS -->
<div class="container my-5">
    <div class="row">

        <div class="col-lg-7 about-section">
            <h4 class="mb-4">Sinopsis</h4>
            <div class="about-content">
                <p><%= book.synopsis %></p>
            </div>

            <div class="mt-4">
                <span class="badge bg-info"><%= book.category %></span>
            </div>

            <hr class="my-5">

            <!-- ULASAN -->
            <h3>Ulasan Pengguna</h3>

            <% if (book.numReviews === 0) { %>
                <p>Belum ada ulasan untuk buku ini.</p>
            <% } %>

        </div>

        <!-- RELATED BOOKS -->
        <div class="col-lg-4 offset-lg-1 you-may-also-like">
            <h4 class="mb-4">You may also like</h4>

            <% if (relatedBooks.length === 0) { %>
                <p class="text-muted">Tidak ada buku terkait.</p>
            <% } else { %>

            <!-- CAROUSEL -->
            <div id="relatedBooksCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">

                    <% for (let i = 0; i < relatedBooks.length; i += 2) { %>
                        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                            <div class="row">

                                <% const slideBooks = relatedBooks.slice(i, i + 2); %>

                                <% slideBooks.forEach(rb => { %>
                                <div class="col-6">
                                    <a href="/store/book/<%= rb._id %>" class="text-decoration-none text-dark">
                                        <div class="card small-related-card">
                                            <img src="<%= rb.coverImage %>" class="card-img-top small-related-img">

                                            <div class="card-body p-1">
                                                <h6 class="card-title mb-1 small-related-title"><%= rb.title %></h6>
                                                <p class="card-text small-related-author"><%= rb.author %></p>
                                                <p class="card-text fw-bold small-related-price">
                                                    Rp <%= rb.price.toLocaleString() %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <% }) %>

                            </div>
                        </div>
                    <% } %>

                </div>

                <!-- CONTROLS -->
                <button class="carousel-control-prev" type="button" data-bs-target="#relatedBooksCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#relatedBooksCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
            
            <% } %>
        </div>

    </div>
</div>

<%- include('../partials/footer') %>
