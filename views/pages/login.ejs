<%- include('../partials/navbar') %>

<div class="container my-5">
    
    <div class="row align-items-center">

        <div class="col-md-6">
            <h1 class="display-5 fw-bold">Welcome back to Litera Bookstore</h1>
            <p class="fs-4 mb-4">Tempat terbaik untuk menemukan buku favoritmu</p>
            
            <img src="/img/landing.jpg" class="img-fluid rounded" alt="Ilustrasi Litera Bookstore">
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Login</h2>
                
                <form action="/login" method="POST">
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" name="email" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" required>
                </div>
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill">Login</button>
                </div>
                </form>
                
                <p class="mt-3 text-center">
                Belum punya akun? <a href="/register">Register di sini</a>
                </p>
            </div>
            </div>
        </div>

    </div> 
</div> 

<%- include('../partials/footer') %>