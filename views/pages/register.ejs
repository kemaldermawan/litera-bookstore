<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - Litera Bookstore Ecosystem</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .animate-fade-in { animation: runFadeIn 0.5s ease-out forwards; }
        @keyframes runFadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary text-uppercase" href="/">Litera</a>
            <div class="d-flex align-items-center ms-auto gap-3">
                <a href="https://facebook.com" target="_blank" class="text-secondary"><i class="bi bi-facebook fs-5"></i></a>
                <a href="https://instagram.com" target="_blank" class="text-secondary"><i class="bi bi-instagram fs-5"></i></a>
            </div>
        </div>
    </nav>

    <div class="container my-5 d-flex align-items-center" style="min-height: 75vh;">
        <div class="row align-items-center g-5 w-100 mx-auto">

            <div class="col-md-6 text-center text-md-start d-none d-md-block">
                <h1 class="display-4 fw-bold text-dark">Join Litera Bookstore</h1>
                <p class="fs-5 text-muted mb-4">Join Litera Bookstore today to start shopping, saving your favorite items, and tracking your physical book deliveries.</p>
                <img src="/img/landing.jpg" class="img-fluid rounded shadow" alt="Litera Bookstore">
            </div>

            <div class="col-md-6">
                <div class="card shadow border-0 p-4 animate-fade-in">
                    <div class="card-body">
                        <h2 class="card-title text-center fw-bold text-dark mb-2">Create Account</h2>
                        <p class="text-muted text-center small mb-4">Please input your factual credential parameters below</p>
                        
                        <form action="/auth/register" method="POST" id="registerForm" class="needs-validation" novalidate>
                            
                            <div class="mb-3">
                                <label for="username" class="form-label small fw-bold">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-person"></i></span>
                                    <input type="text" class="form-control" id="username" name="username" required value="<%= typeof username !== 'undefined' ? username : '' %>" placeholder="Choose a unique username">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label small fw-bold">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-envelope"></i></span>
                                    <input type="email" class="form-control" id="email" name="email" required value="<%= typeof email !== 'undefined' ? email : '' %>" placeholder="name@example.com">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="phone" class="form-label small fw-bold">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-telephone"></i></span>
                                    <input type="text" class="form-control" id="phone" name="phone" required placeholder="e.g., 081234567890">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label small fw-bold">Secure Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-lock"></i></span>
                                    <input type="password" class="form-control" id="password" name="password" required placeholder="Minimum 8 characters">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="confirmPassword" class="form-label small fw-bold">Confirm Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="bi bi-shield-check"></i></span>
                                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required placeholder="Re-enter password">
                                </div>
                                <div id="passwordMismatchInfo" class="text-danger small mt-1 d-none">
                                    <i class="bi bi-exclamation-circle me-1"></i>Passwords do not match. Please ensure both fields are identical.
                                </div>
                            </div>

                            <div class="d-grid mb-2">
                                <button type="submit" id="submitRegisterBtn" class="btn btn-primary fw-bold py-2 rounded-pill shadow-sm">Sign Up</button>
                            </div>
                        </form>

                        <div class="text-center mt-3">
                            <p class="mb-0 text-muted small">Already have an account?
                                <a href="/auth/login" class="text-primary text-decoration-none fw-semibold">Sign In here</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div> 
    </div>

    <footer class="bg-white border-top py-3 text-center text-muted small">
        <div class="container">
            &copy; <%= new Date().getFullYear() %> Litera Bookstore. All rights reserved.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            'use strict';
            const operationalForm = document.getElementById('registerForm');
            const corePasswordInput = document.getElementById('password');
            const verificationPasswordInput = document.getElementById('confirmPassword');
            const structuralErrorMessageNode = document.getElementById('passwordMismatchInfo');
            const transactionSubmissionButton = document.getElementById('submitRegisterBtn');

            function executeTokenSynchronizationValidation() {
                const baseValue = corePasswordInput.value;
                const targetValue = verificationPasswordInput.value;

                if (baseValue === targetValue && baseValue.length > 0) {
                    corePasswordInput.classList.remove('is-invalid');
                    verificationPasswordInput.classList.remove('is-invalid');
                    corePasswordInput.classList.add('is-valid');
                    verificationPasswordInput.classList.add('is-valid');
                    structuralErrorMessageNode.classList.add('d-none');
                    transactionSubmissionButton.disabled = false;
                } else {
                    corePasswordInput.classList.remove('is-valid');
                    verificationPasswordInput.classList.remove('is-valid');
                    if (targetValue.length > 0) {
                        corePasswordInput.classList.add('is-invalid');
                        verificationPasswordInput.classList.add('is-invalid');
                        structuralErrorMessageNode.classList.remove('d-none');
                        transactionSubmissionButton.disabled = true;
                    } else {
                        corePasswordInput.classList.remove('is-invalid');
                        verificationPasswordInput.classList.remove('is-invalid');
                        structuralErrorMessageNode.classList.add('d-none');
                        transactionSubmissionButton.disabled = false;
                    }
                }
            }

            corePasswordInput.addEventListener('input', executeTokenSynchronizationValidation);
            verificationPasswordInput.addEventListener('input', executeTokenSynchronizationValidation);

            operationalForm.addEventListener('submit', function (event) {
                if (corePasswordInput.value.trim() !== verificationPasswordInput.value.trim()) {
                    event.preventDefault();
                    executeTokenSynchronizationValidation();
                }
            });
        })();
    </script>
</body>
</html>