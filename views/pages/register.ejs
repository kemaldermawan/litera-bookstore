<%- include('../partials/navbar') %>

<div class="container my-5">
    
    <div class="row align-items-center">

        <div class="col-md-6">
            <h1 class="display-5 fw-bold">Welcome to Litera Bookstore</h1>
            <p class="fs-4 mb-4">Tempat terbaik untuk menemukan buku favoritmu</p>
            
            <img src="/img/landing.jpg" class="img-fluid rounded" alt="Ilustrasi Litera Bookstore">
        </div>

        <div class="col-md-6">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Register Akun Baru</h2>
                
                <form action="#" method="POST">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username" required>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" name="email" required>
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">No. HP</label>
                    <input type="tel" class="form-control" id="phone" name="phone" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" required>
                </div>
                <div class="mb-3">
                    <label for="password2" class="form-label">Konfirmasi Password</label>
                    <input type="password" class="form-control" id="password2" name="password2" required>
                </div>
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill">Register</button>
                </div>
                </form>
                
                <p class="mt-3 text-center">
                Sudah punya akun? <a href="/login">Login di sini</a>
                </p>
            </div>
        </div>

    </div> 
</div> 
<%- include('../partials/footer') %>